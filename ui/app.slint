import { Button, Date, DatePickerPopup, LineEdit, ScrollView, Time, TimePickerPopup } from "std-widgets.slint";

export struct TabView {
    name: string,
    priority: string,
    selected: bool,
}

export struct TaskView {
    id: int,
    title: string,
    meta: string,
    due_label: string,
    extra: string,
    link_label: string,
    link_url: string,
    is_current: bool,
    has_due_date: bool,
    has_extra: bool,
    has_link: bool,
    progress: float,
}

export struct HistoryView {
    id: int,
    title: string,
    meta: string,
    extra: string,
    link_label: string,
    link_url: string,
    has_extra: bool,
    has_link: bool,
}

export struct TabManagerView {
    name: string,
    priority: string,
    can_delete: bool,
}

component TagChip inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <color> accent;
    in property <color> panel;
    in property <color> text-main;
    in property <color> text-muted;
    in property <float> font-scale: 1.0;
    in property <bool> accessibility-mode: false;
    callback pressed();

    min-width: 68px;
    height: accessibility-mode ? 40px : 34px;
    border-radius: self.height / 2;
    border-width: 1px;
    border-color: selected ? accent : #25324e;
    background: selected ? accent : panel;

    Text {
        x: 14px;
        y: (parent.height - self.height) / 2;
        text: label;
        color: selected ? #08111f : text-muted;
        font-size: 12px * font-scale * (accessibility-mode ? 1.08 : 1.0);
        font-weight: selected ? 700 : 500;
    }

    TouchArea {
        clicked => { root.pressed(); }
    }
}

component RowIconButton inherits Rectangle {
    in property <string> glyph;
    in property <bool> active;
    in property <color> panel;
    in property <color> panel-alt: panel;
    in property <color> accent;
    in property <color> border: accent;
    in property <color> text-main;
    in property <color> text-muted: text-main;
    in property <bool> accessibility-mode: false;
    callback clicked();

    width: accessibility-mode ? 44px : 38px;
    height: accessibility-mode ? 42px : 36px;
    border-radius: 12px;
    border-width: 1px;
    border-color: glyph == "delete" || glyph == "ÃƒÆ’Ã¢â‚¬â€" || glyph == "ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â"
        ? accent
        : (active ? accent : border);
    background: glyph == "delete" || glyph == "ÃƒÆ’Ã¢â‚¬â€" || glyph == "ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â"
        ? panel-alt
        : (active ? panel-alt : panel);

    // check
    if (glyph == "check" || glyph == "âœ“") : Rectangle {
        x: (parent.width - 20px) / 2;
        y: (parent.height - 20px) / 2;
        width: 20px;
        height: 20px;
        border-radius: 10px;
        border-width: 1px;
        border-color: accent;
        background: active ? accent : transparent;

        Rectangle {
            x: 4px;
            y: 10px;
            width: 4px;
            height: 2px;
            border-radius: 1px;
            background: active ? panel : accent;
        }

        Rectangle {
            x: 9px;
            y: 6px;
            width: 4px;
            height: 9px;
            border-radius: 1px;
            background: active ? panel : accent;
        }
    }

    // more
    if (glyph == "more" || glyph == "...") : VerticalLayout {
        x: (parent.width - 4px) / 2;
        y: (parent.height - 14px) / 2;
        width: 4px;
        height: 14px;
        spacing: 3px;

        Rectangle { width: 4px; height: 4px; border-radius: 2px; background: active ? accent : text-muted; }
        Rectangle { width: 4px; height: 4px; border-radius: 2px; background: active ? accent : text-muted; }
        Rectangle { width: 4px; height: 4px; border-radius: 2px; background: active ? accent : text-muted; }
    }

    // current / pin
    if (glyph == "pin-on" || glyph == "pin-off" || glyph == "â—‰" || glyph == "â—Ž" || glyph == "Ã¢â€”â€°" || glyph == "Ã¢â€”Å½") : Rectangle {
        x: (parent.width - 16px) / 2;
        y: (parent.height - 16px) / 2;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        border-width: 1px;
        border-color: accent;
        background: transparent;

        if (glyph == "pin-on" || glyph == "â—‰" || glyph == "Ã¢â€”â€°") : Rectangle {
            x: 4px;
            y: 4px;
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: accent;
        }
    }

    // edit
    if (glyph == "edit" || glyph == "âœŽ" || glyph == "Ã¢Å“Å½") : Rectangle {
        x: (parent.width - 14px) / 2;
        y: (parent.height - 14px) / 2;
        width: 14px;
        height: 14px;
        background: transparent;

        Rectangle {
            x: 3px;
            y: 8px;
            width: 9px;
            height: 2px;
            border-radius: 1px;
            background: text-main;
        }

        Rectangle {
            x: 8px;
            y: 3px;
            width: 3px;
            height: 3px;
            background: accent;
        }

        Rectangle {
            x: 1px;
            y: 10px;
            width: 8px;
            height: 2px;
            border-radius: 1px;
            background: accent;
        }
    }

    // delete
    if (glyph == "delete" || glyph == "Ã—" || glyph == "Ãƒâ€”") : Rectangle {
        x: (parent.width - 14px) / 2;
        y: (parent.height - 14px) / 2;
        width: 14px;
        height: 14px;
        background: transparent;

        Rectangle {
            x: 3px;
            y: 4px;
            width: 8px;
            height: 8px;
            border-radius: 2px;
            border-width: 1px;
            border-color: text-main;
            background: transparent;
        }

        Rectangle {
            x: 2px;
            y: 2px;
            width: 10px;
            height: 2px;
            background: accent;
        }
    }

    // up/down/cycle
    if (glyph == "up" || glyph == "down" || glyph == "cycle" || glyph == "â†‘" || glyph == "â†“" || glyph == "â†º" || glyph == "Ã¢â€ â€˜" || glyph == "Ã¢â€ â€œ" || glyph == "Ã¢â€ Âº") : Rectangle {
        x: (parent.width - 14px) / 2;
        y: (parent.height - 14px) / 2;
        width: 14px;
        height: 14px;
        background: transparent;

        if (glyph == "up" || glyph == "â†‘" || glyph == "Ã¢â€ â€˜") : Text {
            text: "^";
            color: text-main;
            font-size: 14px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        if (glyph == "down" || glyph == "â†“" || glyph == "Ã¢â€ â€œ") : Text {
            text: "v";
            color: text-main;
            font-size: 14px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        if (glyph == "cycle" || glyph == "â†º" || glyph == "Ã¢â€ Âº") : Rectangle {
            x: 2px;
            y: 6px;
            width: 8px;
            height: 2px;
            background: text-main;
        }
        if (glyph == "cycle" || glyph == "â†º" || glyph == "Ã¢â€ Âº") : Rectangle {
            x: 8px;
            y: 4px;
            width: 4px;
            height: 2px;
            background: accent;
        }
        if (glyph == "cycle" || glyph == "â†º" || glyph == "Ã¢â€ Âº") : Rectangle {
            x: 8px;
            y: 8px;
            width: 4px;
            height: 2px;
            background: accent;
        }
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

component HeaderIconButton inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <bool> active;
    in property <bool> enabled: true;
    in property <color> panel;
    in property <color> accent;
    in property <color> text-main;
    in property <color> text-muted;
    in property <float> font-scale: 1.0;
    in property <bool> accessibility-mode: false;
    out property <bool> hovered: hitbox.has-hover;
    callback pressed();

    width: accessibility-mode ? 58px : 52px;
    height: accessibility-mode ? 58px : 52px;
    border-radius: 16px;
    border-width: 1px;
    border-color: active ? accent : #2c3958;
    background: active ? accent : panel;

    VerticalLayout {
        padding-top: 7px;
        padding-bottom: 6px;
        spacing: 1px;

        Text {
            horizontal-alignment: center;
            text: icon;
            color: active ? #08111f : text-main;
            font-size: 18px * font-scale * (accessibility-mode ? 1.08 : 1.0);
            font-weight: 700;
        }

        Text {
            horizontal-alignment: center;
            text: label;
            color: active ? #08111f : text-muted;
            font-size: 9px * font-scale * (accessibility-mode ? 1.08 : 1.0);
            font-weight: active ? 700 : 500;
        }
    }

    hitbox := TouchArea {
        enabled: root.enabled;
        clicked => { root.pressed(); }
    }
}

component AppButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> compact: false;
    in property <color> panel;
    in property <color> panel-alt;
    in property <color> accent;
    in property <color> border;
    in property <color> text-main;
    in property <color> text-muted;
    in property <float> font-scale: 1.0;
    in property <bool> accessibility-mode: false;
    callback clicked();

    min-width: compact ? (accessibility-mode ? 56px : 44px) : (accessibility-mode ? 104px : 84px);
    height: accessibility-mode ? 40px : 34px;
    border-radius: 12px;
    border-width: 1px;
    border-color: danger ? #9a5b5b : (primary ? accent : border);
    background: !enabled ? panel : (danger ? #382829 : (primary ? accent : panel-alt));
    opacity: enabled ? 1 : 0.6;

    Text {
        text: root.text;
        color: danger ? #f1d8d8 : (primary ? #15110b : (enabled ? text-main : text-muted));
        font-size: 12px * font-scale * (accessibility-mode ? 1.08 : 1.0);
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component DragHandle inherits Rectangle {
    in property <int> task-id;
    in property <color> panel;
    in property <color> border;
    in property <color> text-muted;
    in property <bool> accessibility-mode: false;
    callback drag-step(task-id: int, delta: int);

    width: accessibility-mode ? 36px : 30px;
    height: accessibility-mode ? 42px : 36px;
    border-radius: 12px;
    border-width: 1px;
    border-color: border;
    background: panel;
    property <length> drag-origin-y: 0px;

    Text {
        text: "⋮⋮";
        color: text-muted;
        font-size: accessibility-mode ? 16px : 14px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: panel;
        border-radius: 12px;

        VerticalLayout {
            x: (parent.width - 4px) / 2;
            y: (parent.height - 14px) / 2;
            width: 4px;
            height: 14px;
            spacing: 3px;

            Rectangle { width: 4px; height: 4px; border-radius: 2px; background: text-muted; }
            Rectangle { width: 4px; height: 4px; border-radius: 2px; background: text-muted; }
            Rectangle { width: 4px; height: 4px; border-radius: 2px; background: text-muted; }
        }
    }

    drag_touch := TouchArea {
        mouse-cursor: move;

        changed pressed => {
            if (self.pressed) {
                root.drag-origin-y = self.mouse-y;
            }
        }

        moved => {
            if (!self.pressed) {
                return;
            }

            let delta-y = self.mouse-y - root.drag-origin-y;
            if (delta-y > 18px) {
                root.drag-step(root.task-id, 1);
                root.drag-origin-y = self.mouse-y;
            } else if (delta-y < -18px) {
                root.drag-step(root.task-id, -1);
                root.drag-origin-y = self.mouse-y;
            }
        }
    }
}

component TaskCard inherits Rectangle {
    in property <TaskView> task;
    in property <color> panel;
    in property <color> panel-alt;
    in property <color> accent;
    in property <color> border;
    in property <color> text-main;
    in property <color> text-muted;
    callback complete(task-id: int);
    callback edit(task-id: int);
    callback remove(task-id: int);
    callback toggle-current(task-id: int);
    callback move-up(task-id: int);
    callback move-down(task-id: int);
    callback cycle-tab(task-id: int);
    callback set-reminder(task-id: int, minutes: int);
    callback clear-reminder(task-id: int);
    callback set-due-warning(task-id: int, minutes: int);
    callback drag-step(task-id: int, delta: int);
    callback open-link(url: string);
    callback toggle-menu(task-id: int);
    in property <bool> compact-actions: false;
    in property <bool> menu-open: false;
    in property <float> font-scale: 1.0;
    in property <bool> accessibility-mode: false;

    border-radius: 18px;
    border-width: 1px;
    border-color: task.is_current ? accent : border;
    background: task.is_current ? panel-alt : panel;
    card-content := VerticalLayout {
        padding: 14px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 10px;

                RowIconButton {
                    glyph: "✓";
                    active: false;
                    panel: panel;
                    panel-alt: panel-alt;
                    accent: accent;
                    border: border;
                    text-main: text-main;
                    text-muted: text-muted;
                    accessibility-mode: root.accessibility-mode;
                    clicked => { root.complete(task.id); }
                }

            VerticalLayout {
                spacing: task.meta != "" ? 4px : 0px;
                horizontal-stretch: 1;

                if (task.meta == "") : Rectangle {
                    background: transparent;
                    height: accessibility-mode ? 7px : 6px;
                }

                Text {
                    text: task.title;
                    color: text-main;
                    wrap: word-wrap;
                    font-size: 15px * font-scale * (accessibility-mode ? 1.08 : 1.0);
                    font-weight: task.is_current ? 700 : 600;
                }

                if (task.meta != "") : Text {
                    text: task.meta;
                    color: text-muted;
                    font-size: 11px * font-scale * (accessibility-mode ? 1.08 : 1.0);
                    wrap: word-wrap;
                }

                if (task.meta == "") : Rectangle {
                    background: transparent;
                    height: accessibility-mode ? 7px : 6px;
                }
            }

            if (root.menu-open) : Rectangle {
                border-radius: 14px;
                border-width: 1px;
                border-color: border;
                background: task.is_current ? panel : panel-alt;
                height: root.accessibility-mode ? 42px : 36px;
                width: root.accessibility-mode ? 254px : 224px;

                HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 6px;
                    padding-top: 3px;
                    padding-bottom: 3px;
                    spacing: 6px;

                    RowIconButton {
                        glyph: task.is_current ? "pin-on" : "pin-off";
                        active: task.is_current;
                        panel: panel;
                        panel-alt: panel-alt;
                        accent: accent;
                        border: border;
                        text-main: text-main;
                        text-muted: text-muted;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.toggle-current(task.id); }
                    }

                    RowIconButton {
                        glyph: "edit";
                        active: false;
                        panel: panel;
                        panel-alt: panel-alt;
                        accent: accent;
                        border: border;
                        text-main: text-main;
                        text-muted: text-muted;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.edit(task.id); }
                    }

                    RowIconButton {
                        glyph: "delete";
                        active: false;
                        panel: panel;
                        panel-alt: panel-alt;
                        accent: accent;
                        border: border;
                        text-main: text-main;
                        text-muted: text-muted;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.remove(task.id); }
                    }

                    RowIconButton {
                        glyph: "up";
                        active: false;
                        panel: panel;
                        panel-alt: panel-alt;
                        accent: accent;
                        border: border;
                        text-main: text-main;
                        text-muted: text-muted;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.move-up(task.id); }
                    }

                    RowIconButton {
                        glyph: "down";
                        active: false;
                        panel: panel;
                        panel-alt: panel-alt;
                        accent: accent;
                        border: border;
                        text-main: text-main;
                        text-muted: text-muted;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.move-down(task.id); }
                    }
                }
            }

            RowIconButton {
                glyph: "more";
                active: root.menu-open;
                panel: panel;
                panel-alt: panel-alt;
                accent: accent;
                border: border;
                text-main: text-main;
                text-muted: text-muted;
                accessibility-mode: root.accessibility-mode;
                clicked => { root.toggle-menu(task.id); }
            }

            if (false) : HorizontalLayout {
                spacing: 6px;

                RowIconButton {
                    glyph: task.is_current ? "◉" : "◎";
                    active: task.is_current;
                    panel: panel;
                    accent: accent;
                    text-main: text-main;
                    accessibility-mode: root.accessibility-mode;
                    clicked => { root.toggle-current(task.id); }
                }

                RowIconButton {
                    glyph: "✎";
                    active: false;
                    panel: panel;
                    accent: accent;
                    text-main: text-main;
                    accessibility-mode: root.accessibility-mode;
                    clicked => { root.edit(task.id); }
                }

                RowIconButton {
                    glyph: "×";
                    active: false;
                    panel: panel;
                    accent: accent;
                    text-main: text-main;
                    accessibility-mode: root.accessibility-mode;
                    clicked => { root.remove(task.id); }
                }

                RowIconButton {
                    glyph: "↑";
                    active: false;
                    panel: panel;
                    accent: accent;
                    text-main: text-main;
                    accessibility-mode: root.accessibility-mode;
                    clicked => { root.move-up(task.id); }
                }

                RowIconButton {
                    glyph: "↓";
                    active: false;
                    panel: panel;
                    accent: accent;
                    text-main: text-main;
                    accessibility-mode: root.accessibility-mode;
                    clicked => { root.move-down(task.id); }
                }

                RowIconButton {
                    glyph: "↺";
                    active: false;
                    panel: panel;
                    accent: accent;
                    text-main: text-main;
                    accessibility-mode: root.accessibility-mode;
                    clicked => { root.cycle-tab(task.id); }
                }

                DragHandle {
                    task-id: task.id;
                    panel: panel;
                    border: border;
                    text-muted: text-muted;
                    accessibility-mode: root.accessibility-mode;
                    drag-step(task-id, delta) => { root.drag-step(task-id, delta); }
                }
            }
        }

        if (task.has_extra) : Text {
            text: task.extra;
            color: text-muted;
            wrap: word-wrap;
            font-size: 12px * font-scale * (accessibility-mode ? 1.08 : 1.0);
        }

        if (task.has_due_date) : Rectangle {
            border-radius: 10px;
            border-width: 1px;
            border-color: task.is_current ? accent : border;
            background: panel-alt;
            height: accessibility-mode ? 34px : 30px;

            Text {
                x: 10px;
                y: (parent.height - self.height) / 2;
                text: task.due_label;
                color: text-main;
                font-size: 11px * font-scale * (accessibility-mode ? 1.08 : 1.0);
            }
        }

        if (root.menu-open) : Rectangle {
            border-radius: 14px;
            border-width: 1px;
            border-color: border;
            background: panel-alt;
            min-height: accessibility-mode ? 138px : 122px;

            VerticalLayout {
                padding: 10px;
                spacing: 8px;

                Text {
                    text: "Remind me in";
                    color: text-main;
                    font-size: 11px * font-scale;
                    font-weight: 700;
                }

                HorizontalLayout {
                    spacing: 6px;

                    AppButton {
                        text: "5m";
                        compact: true;
                        panel: panel;
                        panel-alt: panel-alt;
                        accent: accent;
                        border: border;
                        text-main: text-main;
                        text-muted: text-muted;
                        font-scale: root.font-scale;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.set-reminder(task.id, 5); }
                    }

                    AppButton {
                        text: "15m";
                        compact: true;
                        panel: panel;
                        panel-alt: panel-alt;
                        accent: accent;
                        border: border;
                        text-main: text-main;
                        text-muted: text-muted;
                        font-scale: root.font-scale;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.set-reminder(task.id, 15); }
                    }

                    AppButton {
                        text: "30m";
                        compact: true;
                        panel: panel;
                        panel-alt: panel-alt;
                        accent: accent;
                        border: border;
                        text-main: text-main;
                        text-muted: text-muted;
                        font-scale: root.font-scale;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.set-reminder(task.id, 30); }
                    }

                    AppButton {
                        text: "Clear";
                        compact: true;
                        panel: panel;
                        panel-alt: panel-alt;
                        accent: accent;
                        border: border;
                        text-main: text-main;
                        text-muted: text-muted;
                        font-scale: root.font-scale;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.clear-reminder(task.id); }
                    }
                }

                Text {
                    text: "Due warning";
                    color: text-main;
                    font-size: 11px * font-scale;
                    font-weight: 700;
                }

                HorizontalLayout {
                    spacing: 6px;

                    AppButton { text: "Off"; compact: true; panel: panel; panel-alt: panel-alt; accent: accent; border: border; text-main: text-main; text-muted: text-muted; font-scale: root.font-scale; accessibility-mode: root.accessibility-mode; clicked => { root.set-due-warning(task.id, 0); } }
                    AppButton { text: "5m"; compact: true; panel: panel; panel-alt: panel-alt; accent: accent; border: border; text-main: text-main; text-muted: text-muted; font-scale: root.font-scale; accessibility-mode: root.accessibility-mode; clicked => { root.set-due-warning(task.id, 5); } }
                    AppButton { text: "15m"; compact: true; panel: panel; panel-alt: panel-alt; accent: accent; border: border; text-main: text-main; text-muted: text-muted; font-scale: root.font-scale; accessibility-mode: root.accessibility-mode; clicked => { root.set-due-warning(task.id, 15); } }
                    AppButton { text: "30m"; compact: true; panel: panel; panel-alt: panel-alt; accent: accent; border: border; text-main: text-main; text-muted: text-muted; font-scale: root.font-scale; accessibility-mode: root.accessibility-mode; clicked => { root.set-due-warning(task.id, 30); } }
                    AppButton { text: "1h"; compact: true; panel: panel; panel-alt: panel-alt; accent: accent; border: border; text-main: text-main; text-muted: text-muted; font-scale: root.font-scale; accessibility-mode: root.accessibility-mode; clicked => { root.set-due-warning(task.id, 60); } }
                }
            }
        }

        if (false) : Rectangle {
            border-radius: 16px;
            border-width: 1px;
            border-color: #4d4035;
            background: #211b17;
            min-height: 96px;

            VerticalLayout {
                padding: 8px;
                spacing: 6px;

                HorizontalLayout {
                    spacing: 6px;

                    RowIconButton {
                        glyph: task.is_current ? "â—‰" : "â—Ž";
                        active: task.is_current;
                        panel: panel;
                        accent: accent;
                        text-main: text-main;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.toggle-current(task.id); }
                    }

                    RowIconButton {
                        glyph: "âœŽ";
                        active: false;
                        panel: panel;
                        accent: accent;
                        text-main: text-main;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.edit(task.id); }
                    }

                    RowIconButton {
                        glyph: "Ã—";
                        active: false;
                        panel: panel;
                        accent: accent;
                        text-main: text-main;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.remove(task.id); }
                    }

                    if (!root.compact-actions) : RowIconButton {
                        glyph: "â†‘";
                        active: false;
                        panel: panel;
                        accent: accent;
                        text-main: text-main;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.move-up(task.id); }
                    }

                    if (!root.compact-actions) : RowIconButton {
                        glyph: "â†“";
                        active: false;
                        panel: panel;
                        accent: accent;
                        text-main: text-main;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.move-down(task.id); }
                    }

                    if (false) : RowIconButton {
                        glyph: "â†º";
                        active: false;
                        panel: panel;
                        accent: accent;
                        text-main: text-main;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.cycle-tab(task.id); }
                    }

                    if (!root.compact-actions) : DragHandle {
                        task-id: task.id;
                        panel: panel;
                        border: border;
                        text-muted: text-muted;
                        accessibility-mode: root.accessibility-mode;
                        drag-step(task-id, delta) => { root.drag-step(task-id, delta); }
                    }
                }

                if (root.compact-actions) : HorizontalLayout {
                    spacing: 6px;

                    RowIconButton {
                        glyph: "â†‘";
                        active: false;
                        panel: panel;
                        accent: accent;
                        text-main: text-main;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.move-up(task.id); }
                    }

                    RowIconButton {
                        glyph: "â†“";
                        active: false;
                        panel: panel;
                        accent: accent;
                        text-main: text-main;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.move-down(task.id); }
                    }

                    if (false) : RowIconButton {
                        glyph: "â†º";
                        active: false;
                        panel: panel;
                        accent: accent;
                        text-main: text-main;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.cycle-tab(task.id); }
                    }

                    DragHandle {
                        task-id: task.id;
                        panel: panel;
                        border: border;
                        text-muted: text-muted;
                        accessibility-mode: root.accessibility-mode;
                        drag-step(task-id, delta) => { root.drag-step(task-id, delta); }
                    }
                }
            }
        }

        if (task.has_due_date) : Rectangle {
            border-radius: 4px;
            background: panel-alt;
            height: accessibility-mode ? 10px : 8px;

            Rectangle {
                x: 0;
                y: 0;
                height: parent.height;
                width: parent.width * task.progress;
                border-radius: 4px;
                background: accent;
            }
        }

        if (task.has_link) : AppButton {
            text: task.link_label;
            panel: panel;
            panel-alt: panel-alt;
            accent: accent;
            border: border;
            text-main: text-main;
            text-muted: text-muted;
            font-scale: root.font-scale;
            accessibility-mode: root.accessibility-mode;
            clicked => { root.open-link(task.link_url); }
        }

        if (false) : HorizontalLayout {
            spacing: 6px;

            RowIconButton {
                glyph: task.is_current ? "◉" : "◎";
                active: task.is_current;
                panel: panel;
                accent: accent;
                text-main: text-main;
                accessibility-mode: root.accessibility-mode;
                clicked => { root.toggle-current(task.id); }
            }

            RowIconButton {
                glyph: "✎";
                active: false;
                panel: panel;
                accent: accent;
                text-main: text-main;
                accessibility-mode: root.accessibility-mode;
                clicked => { root.edit(task.id); }
            }

            RowIconButton {
                glyph: "×";
                active: false;
                panel: panel;
                accent: accent;
                text-main: text-main;
                accessibility-mode: root.accessibility-mode;
                clicked => { root.remove(task.id); }
            }

            RowIconButton {
                glyph: "↑";
                active: false;
                panel: panel;
                accent: accent;
                text-main: text-main;
                accessibility-mode: root.accessibility-mode;
                clicked => { root.move-up(task.id); }
            }

            RowIconButton {
                glyph: "↓";
                active: false;
                panel: panel;
                accent: accent;
                text-main: text-main;
                accessibility-mode: root.accessibility-mode;
                clicked => { root.move-down(task.id); }
            }

            RowIconButton {
                glyph: "↺";
                active: false;
                panel: panel;
                accent: accent;
                text-main: text-main;
                accessibility-mode: root.accessibility-mode;
                clicked => { root.cycle-tab(task.id); }
            }

            DragHandle {
                task-id: task.id;
                panel: panel;
                border: border;
                text-muted: text-muted;
                accessibility-mode: root.accessibility-mode;
                drag-step(task-id, delta) => { root.drag-step(task-id, delta); }
            }
        }
    }

    height: Math.max(card-content.preferred-height + 28px, accessibility-mode ? 86px : 72px);
}

component HistoryCard inherits Rectangle {
    in property <HistoryView> entry;
    in property <color> panel;
    in property <color> border;
    in property <color> accent;
    in property <color> text-main;
    in property <color> text-muted;
    in property <float> font-scale: 1.0;
    in property <bool> accessibility-mode: false;
    callback restore(task-id: int);
    callback open-link(url: string);

    border-radius: 18px;
    border-width: 1px;
    border-color: border;
    background: panel;
    min-height: entry.has_extra ? (accessibility-mode ? 138px : 128px) : (accessibility-mode ? 114px : 104px);

    VerticalLayout {
        padding: 14px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 10px;

            Rectangle {
                width: 18px;
                height: 18px;
                border-radius: 9px;
                background: accent;
            }

            VerticalLayout {
                spacing: 4px;
                horizontal-stretch: 1;

                Text {
                    text: entry.title;
                    color: text-main;
                    wrap: word-wrap;
                    font-size: 15px * font-scale * (accessibility-mode ? 1.08 : 1.0);
                    font-weight: 600;
                }

                if (entry.meta != "") : Text {
                    text: entry.meta;
                    color: text-muted;
                    wrap: word-wrap;
                    font-size: 11px * font-scale * (accessibility-mode ? 1.08 : 1.0);
                }
            }

            AppButton {
                text: "Restore";
                panel: panel;
                panel-alt: panel;
                accent: accent;
                border: border;
                text-main: text-main;
                text-muted: text-muted;
                font-scale: root.font-scale;
                accessibility-mode: root.accessibility-mode;
                clicked => { root.restore(entry.id); }
            }
        }

        if (entry.has_extra) : Text {
            text: entry.extra;
            color: text-muted;
            wrap: word-wrap;
            font-size: 12px * font-scale * (accessibility-mode ? 1.08 : 1.0);
        }

        if (entry.has_link) : AppButton {
            text: entry.link_label;
            panel: panel;
            panel-alt: panel;
            accent: accent;
            border: border;
            text-main: text-main;
            text-muted: text-muted;
            font-scale: root.font-scale;
            accessibility-mode: root.accessibility-mode;
            clicked => { root.open-link(entry.link_url); }
        }
    }
}

component TabManagerCard inherits Rectangle {
    in property <TabManagerView> tab;
    in property <color> panel;
    in property <color> border;
    in property <color> accent;
    in property <color> text-main;
    in property <color> text-muted;
    in property <float> font-scale: 1.0;
    in property <bool> accessibility-mode: false;
    callback move-up(name: string);
    callback move-down(name: string);
    callback remove(name: string);

    border-radius: 16px;
    border-width: 1px;
    border-color: border;
    background: panel;
    min-height: 82px;

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;

            VerticalLayout {
                spacing: 2px;
                horizontal-stretch: 1;

                Text {
                    text: tab.name;
                    color: text-main;
                    font-size: 14px * font-scale * (accessibility-mode ? 1.08 : 1.0);
                    font-weight: 700;
                }

                Text {
                    text: "Priority: " + tab.priority;
                    color: text-muted;
                    font-size: 11px * font-scale * (accessibility-mode ? 1.08 : 1.0);
                }
            }

            AppButton {
                text: "Up";
                panel: panel;
                panel-alt: panel;
                accent: accent;
                border: border;
                text-main: text-main;
                text-muted: text-muted;
                font-scale: root.font-scale;
                accessibility-mode: root.accessibility-mode;
                clicked => { root.move-up(tab.name); }
            }

            AppButton {
                text: "Down";
                panel: panel;
                panel-alt: panel;
                accent: accent;
                border: border;
                text-main: text-main;
                text-muted: text-muted;
                font-scale: root.font-scale;
                accessibility-mode: root.accessibility-mode;
                clicked => { root.move-down(tab.name); }
            }

            if (tab.can_delete) : AppButton {
                text: "Delete";
                danger: true;
                panel: panel;
                panel-alt: panel;
                accent: accent;
                border: border;
                text-main: text-main;
                text-muted: text-muted;
                font-scale: root.font-scale;
                accessibility-mode: root.accessibility-mode;
                clicked => { root.remove(tab.name); }
            }
        }
    }
}

export component AppWindow inherits Window {
    icon: @image-url("focus-logo.svg");
    in-out property <string> app-title: "focus";
    in-out property <string> status-text: "Loading";
    in-out property <string> footer-text: "";
    in-out property <bool> on-top-enabled: true;
    in-out property <int> task-menu-id: -1;
    in-out property <string> current-title: "";
    in-out property <string> current-meta: "";
    in-out property <string> active-tab-name: "All";
    in-out property <[TabView]> tabs: [];
    in-out property <[TaskView]> tasks: [];
    in-out property <[HistoryView]> history-items: [];
    in-out property <[TabManagerView]> managed-tabs: [];
    in-out property <int> pending-count: 0;
    in-out property <int> done-today-count: 0;
    in-out property <int> done-month-count: 0;
    in-out property <int> done-year-count: 0;
    in-out property <string> draft-title: "";
    in-out property <string> draft-extra: "";
    in-out property <string> draft-due-date: "";
    in-out property <bool> draft-has-due: false;
    in-out property <string> draft-message: "";
    in-out property <string> draft-tab-name: "";
    in-out property <int> draft-due-picker-year: 0;
    in-out property <int> draft-due-picker-month: 0;
    in-out property <int> draft-due-picker-day: 0;
    in-out property <int> draft-due-picker-hour: 0;
    in-out property <int> draft-due-picker-minute: 0;
    in-out property <string> transfer-path: "";
    in-out property <string> tools-message: "";
    in-out property <bool> sync-enabled: false;
    in-out property <string> sync-provider: "local_file";
    in-out property <string> sync-path: "";
    in-out property <string> sync-device-id: "";
    in-out property <string> sync-google-client-id: "";
    in-out property <string> sync-google-file-id: "";
    in-out property <string> sync-message: "";
    in-out property <bool> notifications-enabled: true;
    in-out property <bool> notify-only-when-app-hidden: false;
    in-out property <bool> notification-sound-enabled: true;
    in-out property <string> notification-sound-path: "";
    in-out property <string> default-due-warning-label: "Off";
    in-out property <bool> startup-enabled: false;
    in-out property <string> startup-message: "";
    in-out property <string> about-version: "";
    in-out property <string> about-commit: "";
    in-out property <string> about-repo-url: "";
    in-out property <float> font-scale: 1.0;
    in-out property <string> font-scale-label: "100%";
    in-out property <bool> accessibility-mode: false;
    in-out property <bool> show-item-meta: true;
    in-out property <bool> editing-mode: false;
    in-out property <bool> draft-visible: false;
    in-out property <bool> can-undo: false;
    in-out property <bool> history-visible: false;
    in-out property <bool> tools-visible: false;
    in-out property <bool> tab-overflow: false;
    in-out property <bool> can-shift-tabs-left: false;
    in-out property <bool> can-shift-tabs-right: false;

    callback add-task();
    callback show-history();
    callback show-tools();
    callback toggle-on-top();
    callback select-tab(name: string);
    callback submit-draft();
    callback cancel-draft();
    callback draft-due-picked(year: int, month: int, day: int, hour: int, minute: int);
    callback complete-task(task-id: int);
    callback edit-task(task-id: int);
    callback delete-task(task-id: int);
    callback toggle-current(task-id: int);
    callback undo-complete();
    callback restore-history(task-id: int);
    callback move-task-up(task-id: int);
    callback move-task-down(task-id: int);
    callback cycle-task-tab(task-id: int);
    callback set-task-reminder(task-id: int, minutes: int);
    callback clear-task-reminder(task-id: int);
    callback set-task-due-warning(task-id: int, minutes: int);
    callback drag-task-step(task-id: int, delta: int);
    callback toggle-task-menu(task-id: int);
    callback submit-tab();
    callback move-tab-up(name: string);
    callback move-tab-down(name: string);
    callback delete-tab(name: string);
    callback import-data();
    callback export-data();
    callback apply-theme-preset(name: string);
    callback decrease-font-scale();
    callback increase-font-scale();
    callback toggle-accessibility-mode();
    callback toggle-item-meta();
    callback toggle-startup();
    callback open-task-link(url: string);
    callback open-project-link();
    callback open-sync-info();
    callback save-notification-config();
    callback choose-notification-sound();
    callback clear-notification-sound();
    callback test-notification-sound();
    callback save-sync-config();
    callback choose-sync-path();
    callback sync-now();
    callback shift-tabs-left();
    callback shift-tabs-right();
    callback tab-strip-resized(width: float);

    title: app-title;
    preferred-width: 460px;
    preferred-height: 740px;
    min-width: 360px;
    min-height: 520px;
    background: root.bg;

    in-out property <color> bg: #0b1120;
    in-out property <color> panel: #121a2b;
    in-out property <color> panel-alt: #17233a;
    in-out property <color> panel-soft: #0f1728;
    in-out property <color> accent: #75e6da;
    in-out property <color> accent-warm: #f7c873;
    in-out property <color> text-main: #f7f8fc;
    in-out property <color> text-muted: #94a3b8;
    in-out property <color> border: #24314d;
    property <float> effective-font-scale: font-scale * (accessibility-mode ? 1.08 : 1.0);
    property <length> font-caption: 11px * effective-font-scale;
    property <length> font-body: 12px * effective-font-scale;
    property <length> font-section: 15px * effective-font-scale;
    property <length> font-title: 18px * effective-font-scale;
    property <length> font-app-title: 24px * effective-font-scale;
    property <bool> has-current-task: current-title != "";
    property <bool> main-visible: !history-visible && !tools-visible;
    property <bool> compact-task-actions: self.width < 520px;

    VerticalLayout {
        padding: 14px;
        spacing: 12px;

        header_shell := Rectangle {
            clip: true;
            border-radius: 24px;
            border-width: 1px;
            border-color: root.border;
            background: root.panel-alt;
            height: 88px;
            property <bool> show-header-actions: header_hover.has-hover || add_action.hovered || history_action.hovered || tools_action.hovered || pin_action.hovered;

            header_hover := TouchArea {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;
            }

            HorizontalLayout {
                padding: 16px;
                spacing: 0;

                title_zone := Rectangle {
                    horizontal-stretch: 1;
                    height: parent.height;
                    background: transparent;

                    VerticalLayout {
                        width: parent.width;
                        height: parent.height;
                        padding-top: 6px;
                        padding-bottom: 6px;
                        spacing: 2px;

                        Text {
                            text: root.app-title;
                            color: root.text-main;
                            font-size: root.font-app-title;
                            font-weight: 800;
                        }

                        if (root.status-text != "") : Text {
                            text: root.status-text;
                            color: root.text-muted;
                            font-size: root.font-body;
                            wrap: word-wrap;
                        }
                    }
                }

                actions_zone := Rectangle {
                    width: 232px;
                    height: parent.height;
                    background: transparent;
                    opacity: header_shell.show-header-actions ? 1 : 0;

                    HorizontalLayout {
                        width: parent.width;
                        height: parent.height;
                        spacing: 6px;

                        add_action := HeaderIconButton {
                            icon: "+";
                            label: "add";
                            active: root.draft-visible && root.main-visible;
                            panel: root.panel-alt;
                            accent: root.accent-warm;
                            text-main: root.text-main;
                            text-muted: root.text-muted;
                            font-scale: root.font-scale;
                            accessibility-mode: root.accessibility-mode;
                            pressed => { root.add-task(); }
                        }

                        history_action := HeaderIconButton {
                            icon: root.history-visible ? "<" : "↺";
                            label: "history";
                            active: root.history-visible;
                            panel: root.panel-alt;
                            accent: root.accent-warm;
                            text-main: root.text-main;
                            text-muted: root.text-muted;
                            font-scale: root.font-scale;
                            accessibility-mode: root.accessibility-mode;
                            pressed => { root.show-history(); }
                        }

                        tools_action := HeaderIconButton {
                            icon: root.tools-visible ? "<" : "☰";
                            label: "tools";
                            active: root.tools-visible;
                            panel: root.panel-alt;
                            accent: root.accent-warm;
                            text-main: root.text-main;
                            text-muted: root.text-muted;
                            font-scale: root.font-scale;
                            accessibility-mode: root.accessibility-mode;
                            pressed => { root.show-tools(); }
                        }

                        pin_action := HeaderIconButton {
                            icon: root.on-top-enabled ? "◉" : "◎";
                            label: "pin";
                            active: root.on-top-enabled;
                            panel: root.panel-alt;
                            accent: root.accent;
                            text-main: root.text-main;
                            text-muted: root.text-muted;
                            font-scale: root.font-scale;
                            accessibility-mode: root.accessibility-mode;
                            pressed => { root.toggle-on-top(); }
                        }
                    }
                }
            }
        }

        if (root.draft-visible && root.main-visible) : Rectangle {
            border-radius: 22px;
            border-width: 1px;
            border-color: root.border;
            background: root.panel;
            min-height: 126px;

            VerticalLayout {
                padding: 14px;
                spacing: 8px;

                Text {
                    text: root.editing-mode ? "Edit task" : "Quick add";
                    color: root.text-main;
                    font-size: root.font-section;
                    font-weight: 700;
                }

                LineEdit {
                    text <=> root.draft-title;
                    placeholder-text: "Task title";
                }

                LineEdit {
                    text <=> root.draft-extra;
                    placeholder-text: "Extra info (optional)";
                }

                HorizontalLayout {
                    height: root.accessibility-mode ? 40px : 34px;
                    spacing: 8px;

                    AppButton {
                        text: root.draft-has-due ? "Change due date" : "Set due date";
                        panel: root.panel;
                        panel-alt: root.panel-alt;
                        accent: root.accent;
                        border: root.border;
                        text-main: root.text-main;
                        text-muted: root.text-muted;
                        font-scale: root.font-scale;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { due_date_picker.show(); }
                    }

                    if (root.draft-has-due) : AppButton {
                        text: "Clear due";
                        danger: true;
                        panel: root.panel;
                        panel-alt: root.panel-alt;
                        accent: root.accent;
                        border: root.border;
                        text-main: root.text-main;
                        text-muted: root.text-muted;
                        font-scale: root.font-scale;
                        accessibility-mode: root.accessibility-mode;
                        clicked => {
                            root.draft-due-date = "";
                            root.draft-has-due = false;
                        }
                    }
                }

                if (root.draft-has-due) : Text {
                    text: "Due " + root.draft-due-date;
                    color: root.text-muted;
                    wrap: word-wrap;
                    font-size: root.font-caption;
                }

                if (root.draft-message != "") : Text {
                    text: root.draft-message;
                    color: root.accent-warm;
                    wrap: word-wrap;
                    font-size: root.font-caption;
                }

                HorizontalLayout {
                    spacing: 8px;

                    AppButton {
                        text: root.editing-mode ? "Save" : "Create";
                        primary: true;
                        panel: root.panel;
                        panel-alt: root.panel-alt;
                        accent: root.accent-warm;
                        border: root.border;
                        text-main: root.text-main;
                        text-muted: root.text-muted;
                        font-scale: root.font-scale;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.submit-draft(); }
                    }

                    AppButton {
                        text: "Cancel";
                        enabled: root.editing-mode || root.draft-title != "" || root.draft-extra != "" || root.draft-has-due || root.draft-due-date != "";
                        panel: root.panel;
                        panel-alt: root.panel-alt;
                        accent: root.accent;
                        border: root.border;
                        text-main: root.text-main;
                        text-muted: root.text-muted;
                        font-scale: root.font-scale;
                        accessibility-mode: root.accessibility-mode;
                        clicked => { root.cancel-draft(); }
                    }
                }
            }
        }

        due_date_picker := DatePickerPopup {
            title: "Select due date";
            date: {
                year: root.draft-due-picker-year,
                month: root.draft-due-picker-month,
                day: root.draft-due-picker-day
            };

            accepted(date) => {
                root.draft-due-picker-year = date.year;
                root.draft-due-picker-month = date.month;
                root.draft-due-picker-day = date.day;
                time_picker.show();
            }
        }

        time_picker := TimePickerPopup {
            title: "Select due time";
            use-24-hour-format: true;
            time: {
                hour: root.draft-due-picker-hour,
                minute: root.draft-due-picker-minute,
                second: 0
            };

            accepted(time) => {
                root.draft-due-picker-hour = time.hour;
                root.draft-due-picker-minute = time.minute;
                root.draft-due-picked(
                    root.draft-due-picker-year,
                    root.draft-due-picker-month,
                    root.draft-due-picker-day,
                    time.hour,
                    time.minute
                );
            }
        }

        if (root.main-visible) : Rectangle {
            border-radius: 24px;
            border-width: 1px;
            border-color: root.border;
            background: root.panel;
            vertical-stretch: 1;

            VerticalLayout {
                padding: 14px;
                spacing: 12px;

                HorizontalLayout {
                    spacing: 8px;

                    if (root.tab-overflow) : HeaderIconButton {
                        icon: "←";
                        label: "";
                        active: false;
                        enabled: root.can-shift-tabs-left;
                        panel: root.panel-soft;
                        accent: root.accent;
                        text-main: root.text-main;
                        text-muted: root.text-muted;
                        font-scale: root.font-scale;
                        accessibility-mode: root.accessibility-mode;
                        width: root.accessibility-mode ? 40px : 34px;
                        height: root.accessibility-mode ? 40px : 34px;
                        pressed => { root.shift-tabs-left(); }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: root.accessibility-mode ? 40px : 34px;
                        background: transparent;

                        changed width => {
                            root.tab-strip-resized(self.width / 1px);
                        }

                        HorizontalLayout {
                            width: parent.width;
                            height: parent.height;
                            spacing: 8px;

                    for tab in root.tabs : TagChip {
                        label: tab.name;
                        selected: tab.selected;
                        accent: root.accent;
                        panel: root.panel-soft;
                        text-main: root.text-main;
                        text-muted: root.text-muted;
                        font-scale: root.font-scale;
                        accessibility-mode: root.accessibility-mode;
                        pressed => { root.select-tab(tab.name); }
                    }
                        }
                    }

                    if (root.tab-overflow) : HeaderIconButton {
                        icon: "→";
                        label: "";
                        active: false;
                        enabled: root.can-shift-tabs-right;
                        panel: root.panel-soft;
                        accent: root.accent;
                        text-main: root.text-main;
                        text-muted: root.text-muted;
                        font-scale: root.font-scale;
                        accessibility-mode: root.accessibility-mode;
                        width: root.accessibility-mode ? 40px : 34px;
                        height: root.accessibility-mode ? 40px : 34px;
                        pressed => { root.shift-tabs-right(); }
                    }
                }

                Rectangle {
                    height: 1px;
                    background: root.border;
                }

                if (root.tasks.length == 0) : Rectangle {
                    border-radius: 18px;
                    border-width: 1px;
                    border-color: root.border;
                    background: root.panel-soft;
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 20px;
                        spacing: 8px;

                        Text {
                            text: "No tasks in this view";
                            color: root.text-main;
                            font-size: root.font-title;
                            font-weight: 700;
                        }

                        Text {
                            text: "Use Add in the header to create the next task.";
                            color: root.text-muted;
                            wrap: word-wrap;
                            font-size: root.font-body;
                        }
                    }
                }

                if (root.tasks.length > 0) : ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 10px;
                        padding-right: 12px;

                        for task[index] in root.tasks : TaskCard {
                            task: task;
                            compact-actions: root.compact-task-actions;
                            menu-open: root.task-menu-id == task.id;
                            font-scale: root.font-scale;
                            accessibility-mode: root.accessibility-mode;
                            panel: Math.mod(index, 2) == 0 ? root.panel-soft : root.panel;
                            panel-alt: root.panel-alt;
                            accent: root.accent;
                            border: root.border;
                            text-main: root.text-main;
                            text-muted: root.text-muted;
                            complete(task-id) => { root.complete-task(task-id); }
                            edit(task-id) => { root.edit-task(task-id); }
                            remove(task-id) => { root.delete-task(task-id); }
                            toggle-current(task-id) => { root.toggle-current(task-id); }
                            move-up(task-id) => { root.move-task-up(task-id); }
                            move-down(task-id) => { root.move-task-down(task-id); }
                            cycle-tab(task-id) => { root.cycle-task-tab(task-id); }
                            set-reminder(task-id, minutes) => { root.set-task-reminder(task-id, minutes); }
                            clear-reminder(task-id) => { root.clear-task-reminder(task-id); }
                            set-due-warning(task-id, minutes) => { root.set-task-due-warning(task-id, minutes); }
                            drag-step(task-id, delta) => { root.drag-task-step(task-id, delta); }
                            open-link(url) => { root.open-task-link(url); }
                            toggle-menu(task-id) => { root.toggle-task-menu(task-id); }
                        }
                    }
                }
            }
        }

        if (root.history-visible) : Rectangle {
            border-radius: 24px;
            border-width: 1px;
            border-color: root.border;
            background: root.panel;
            vertical-stretch: 1;

            VerticalLayout {
                padding: 14px;
                spacing: 10px;

                Text {
                    text: "History";
                    color: root.text-main;
                    font-size: root.font-title;
                    font-weight: 700;
                }

                Text {
                    text: "Completed tasks";
                    color: root.text-muted;
                    font-size: root.font-body;
                }

                Rectangle {
                    height: 1px;
                    background: root.border;
                }

                if (root.history-items.length == 0) : Rectangle {
                    border-radius: 18px;
                    border-width: 1px;
                    border-color: root.border;
                    background: root.panel-soft;
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 20px;
                        spacing: 8px;

                        Text {
                            text: "No completed tasks yet";
                            color: root.text-main;
                            font-size: root.font-title;
                            font-weight: 700;
                        }

                        Text {
                            text: "Completed tasks will appear here and can be restored.";
                            color: root.text-muted;
                            wrap: word-wrap;
                            font-size: root.font-body;
                        }
                    }
                }

                if (root.history-items.length > 0) : ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 10px;
                        padding-right: 12px;

                        for entry[index] in root.history-items : HistoryCard {
                            entry: entry;
                            font-scale: root.font-scale;
                            accessibility-mode: root.accessibility-mode;
                            panel: Math.mod(index, 2) == 0 ? root.panel-soft : root.panel;
                            border: root.border;
                            accent: root.accent-warm;
                            text-main: root.text-main;
                            text-muted: root.text-muted;
                            restore(task-id) => { root.restore-history(task-id); }
                            open-link(url) => { root.open-task-link(url); }
                        }
                    }
                }
            }
        }

        if (root.tools-visible) : Rectangle {
            border-radius: 24px;
            border-width: 1px;
            border-color: root.border;
            background: root.panel;
            vertical-stretch: 1;

            VerticalLayout {
                padding: 14px;
                spacing: 10px;

                Text {
                    text: "Tools";
                    color: root.text-main;
                    font-size: root.font-title;
                    font-weight: 700;
                }

                Text {
                    text: "Configuration and data management";
                    color: root.text-muted;
                    font-size: root.font-body;
                }

                Rectangle {
                    height: 1px;
                    background: root.border;
                }

                ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 12px;
                        padding-right: 10px;

                        Rectangle {
                            border-radius: 18px;
                            border-width: 1px;
                            border-color: root.border;
                            background: root.panel-soft;
                            min-height: 134px;

                            VerticalLayout {
                                padding: 14px;
                                padding-bottom: 18px;
                                spacing: 8px;

                                Text {
                                    text: "Add tab";
                                    color: root.text-main;
                                    font-size: root.font-section;
                                    font-weight: 700;
                                }

                                LineEdit {
                                    text <=> root.draft-tab-name;
                                    placeholder-text: "New tab name";
                                }

                                AppButton {
                                    text: "Create tab";
                                    primary: true;
                                    panel: root.panel;
                                    panel-alt: root.panel-alt;
                                    accent: root.accent;
                                    border: root.border;
                                    text-main: root.text-main;
                                    text-muted: root.text-muted;
                                    font-scale: root.font-scale;
                                    accessibility-mode: root.accessibility-mode;
                                    clicked => { root.submit-tab(); }
                                }
                            }
                        }

                        Rectangle {
                            border-radius: 18px;
                            border-width: 1px;
                            border-color: root.border;
                            background: root.panel-soft;
                            min-height: 286px;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "Notifications";
                                    color: root.text-main;
                                    font-size: root.font-section;
                                    font-weight: 700;
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    AppButton {
                                        text: root.notifications-enabled ? "Notifications on" : "Notifications off";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.notifications-enabled = !root.notifications-enabled; root.save-notification-config(); }
                                    }

                                    AppButton {
                                        text: root.notify-only-when-app-hidden ? "Only when hidden" : "Show while focused";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.notify-only-when-app-hidden = !root.notify-only-when-app-hidden; root.save-notification-config(); }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    AppButton {
                                        text: root.notification-sound-enabled ? "Sound on" : "Sound off";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent-warm;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.notification-sound-enabled = !root.notification-sound-enabled; root.save-notification-config(); }
                                    }

                                    AppButton {
                                        text: "Choose sound";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.choose-notification-sound(); }
                                    }

                                    AppButton {
                                        text: "Clear sound";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.clear-notification-sound(); }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: "Default due warning: " + root.default-due-warning-label;
                                        color: root.text-main;
                                        vertical-alignment: center;
                                        font-size: root.font-body;
                                    }

                                    AppButton {
                                        text: "Off";
                                        compact: true;
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.default-due-warning-label = "Off"; }
                                    }

                                    AppButton {
                                        text: "5m";
                                        compact: true;
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.default-due-warning-label = "5m"; }
                                    }

                                    AppButton {
                                        text: "15m";
                                        compact: true;
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.default-due-warning-label = "15m"; }
                                    }

                                    AppButton {
                                        text: "30m";
                                        compact: true;
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.default-due-warning-label = "30m"; }
                                    }

                                    AppButton {
                                        text: "1h";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.default-due-warning-label = "1h"; }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    AppButton {
                                        text: "Save notification settings";
                                        primary: true;
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.save-notification-config(); }
                                    }

                                    AppButton {
                                        text: "Test sound";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent-warm;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.test-notification-sound(); }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            border-radius: 18px;
                            border-width: 1px;
                            border-color: root.border;
                            background: root.panel-soft;
                            min-height: 144px;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "System";
                                    color: root.text-main;
                                    font-size: root.font-section;
                                    font-weight: 700;
                                }

                                Text {
                                    text: "Launch focus automatically when you sign in on Windows or Linux.";
                                    color: root.text-muted;
                                    wrap: word-wrap;
                                    font-size: root.font-body;
                                }

                                AppButton {
                                    text: root.startup-enabled ? "Launch on login enabled" : "Launch on login disabled";
                                    panel: root.panel;
                                    panel-alt: root.panel-alt;
                                    accent: root.accent;
                                    border: root.border;
                                    text-main: root.text-main;
                                    text-muted: root.text-muted;
                                    font-scale: root.font-scale;
                                    accessibility-mode: root.accessibility-mode;
                                    clicked => { root.toggle-startup(); }
                                }

                                if (root.startup-message != "") : Text {
                                    text: root.startup-message;
                                    color: root.text-muted;
                                    wrap: word-wrap;
                                    font-size: root.font-body;
                                }
                            }
                        }

                        Rectangle {
                            border-radius: 18px;
                            border-width: 1px;
                            border-color: root.border;
                            background: root.panel-soft;
                            min-height: 166px;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "Accessibility and text";
                                    color: root.text-main;
                                    font-size: root.font-section;
                                    font-weight: 700;
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    AppButton {
                                        text: "A-";
                                        compact: true;
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.decrease-font-scale(); }
                                    }

                                    Rectangle {
                                        border-radius: 12px;
                                        border-width: 1px;
                                        border-color: root.border;
                                        background: root.panel;
                                        min-width: 84px;
                                        height: root.accessibility-mode ? 40px : 34px;

                                        Text {
                                            text: root.font-scale-label;
                                            color: root.text-main;
                                            font-size: root.font-body;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    AppButton {
                                        text: "A+";
                                        compact: true;
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.increase-font-scale(); }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    AppButton {
                                        text: root.accessibility-mode ? "Accessibility on" : "Accessibility off";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.toggle-accessibility-mode(); }
                                    }

                                    AppButton {
                                        text: root.show-item-meta ? "Metadata visible" : "Titles only";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.toggle-item-meta(); }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            border-radius: 18px;
                            border-width: 1px;
                            border-color: root.border;
                            background: root.panel-soft;
                            min-height: 146px;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "Appearance presets";
                                    color: root.text-main;
                                    font-size: root.font-section;
                                    font-weight: 700;
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    AppButton {
                                        text: "Warm";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent-warm;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.apply-theme-preset("warm"); }
                                    }

                                    AppButton {
                                        text: "Forest";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent-warm;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.apply-theme-preset("forest"); }
                                    }

                                    AppButton {
                                        text: "Ocean";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent-warm;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.apply-theme-preset("ocean"); }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    AppButton {
                                        text: "Rose";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent-warm;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.apply-theme-preset("rose"); }
                                    }

                                    AppButton {
                                        text: "Dark";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent-warm;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.apply-theme-preset("dark"); }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            border-radius: 18px;
                            border-width: 1px;
                            border-color: root.border;
                            background: root.panel-soft;
                            min-height: root.sync-provider == "google_drive" ? 528px : 336px;

                            VerticalLayout {
                                padding: 14px;
                                padding-bottom: 18px;
                                spacing: 10px;

                                Text {
                                    text: "External sync";
                                    color: root.text-main;
                                    font-size: root.font-section;
                                    font-weight: 700;
                                }

                                Text {
                                    text: root.sync-provider == "google_drive"
                                        ? "Use the same focus-sync.json stored in Google Drive."
                                        : "Use a shared focus-sync.json for desktop and Android.";
                                    color: root.text-muted;
                                    wrap: word-wrap;
                                    font-size: root.font-body;
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    AppButton {
                                        text: "Local file";
                                        primary: root.sync-provider == "local_file";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.sync-provider = "local_file"; }
                                    }

                                    AppButton {
                                        text: "Google Drive";
                                        primary: root.sync-provider == "google_drive";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent-warm;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.sync-provider = "google_drive"; }
                                    }
                                }

                                if (root.sync-provider == "local_file") : LineEdit {
                                    text: root.sync-path != "" ? root.sync-path : "No sync file selected";
                                    read-only: true;
                                }

                                if (root.sync-provider == "local_file") : AppButton {
                                    text: "Browse sync file";
                                    panel: root.panel;
                                    panel-alt: root.panel-alt;
                                    accent: root.accent;
                                    border: root.border;
                                    text-main: root.text-main;
                                    text-muted: root.text-muted;
                                    font-scale: root.font-scale;
                                    accessibility-mode: root.accessibility-mode;
                                    clicked => { root.choose-sync-path(); }
                                }

                                if (root.sync-provider == "google_drive") : Rectangle {
                                    border-radius: 14px;
                                    border-width: 1px;
                                    border-color: root.border;
                                    background: root.panel;
                                    min-height: 184px;

                                    VerticalLayout {
                                        padding: 10px;
                                        spacing: 8px;

                                        Text {
                                            text: "1. Create a Desktop OAuth client in Google Cloud.";
                                            color: root.text-muted;
                                            wrap: word-wrap;
                                            font-size: root.font-body;
                                        }

                                        Text {
                                            text: "2. Copy the Drive file ID from the JSON file URL.";
                                            color: root.text-muted;
                                            wrap: word-wrap;
                                            font-size: root.font-body;
                                        }

                                        Text {
                                            text: "3. Device id is just this machine label. Leave the default unless you sync several computers.";
                                            color: root.text-muted;
                                            wrap: word-wrap;
                                            font-size: root.font-body;
                                        }

                                        LineEdit {
                                            text <=> root.sync-google-client-id;
                                            placeholder-text: "Desktop OAuth client_id";
                                        }

                                        LineEdit {
                                            text <=> root.sync-google-file-id;
                                            placeholder-text: "Shared Drive file_id";
                                        }
                                    }
                                }

                                Text {
                                    text: "Device id: local name for this computer.";
                                    color: root.text-muted;
                                    wrap: word-wrap;
                                    font-size: root.font-body;
                                }

                                LineEdit {
                                    text <=> root.sync-device-id;
                                    placeholder-text: "e.g. focus-laptop";
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    AppButton {
                                        text: root.sync-enabled ? "Sync enabled" : "Sync disabled";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.sync-enabled = !root.sync-enabled; }
                                    }

                                    AppButton {
                                        text: "Save sync config";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.save-sync-config(); }
                                    }
                                }

                                AppButton {
                                    text: "Sync now";
                                    primary: true;
                                    panel: root.panel;
                                    panel-alt: root.panel-alt;
                                    accent: root.accent;
                                    border: root.border;
                                    text-main: root.text-main;
                                    text-muted: root.text-muted;
                                    font-scale: root.font-scale;
                                    accessibility-mode: root.accessibility-mode;
                                    clicked => { root.sync-now(); }
                                }

                                AppButton {
                                    text: "Info";
                                    panel: root.panel;
                                    panel-alt: root.panel-alt;
                                    accent: root.accent-warm;
                                    border: root.border;
                                    text-main: root.text-main;
                                    text-muted: root.text-muted;
                                    font-scale: root.font-scale;
                                    accessibility-mode: root.accessibility-mode;
                                    clicked => { root.open-sync-info(); }
                                }

                                if (root.sync-message != "") : Rectangle {
                                    border-radius: 12px;
                                    border-width: 1px;
                                    border-color: root.border;
                                    background: root.panel;
                                    min-height: 52px;

                                    Text {
                                        x: 10px;
                                        y: 8px;
                                        width: parent.width - 20px;
                                        text: root.sync-message;
                                        color: root.text-muted;
                                        wrap: word-wrap;
                                        font-size: root.font-body;
                                    }
                                }
                            }
                        }

                        Rectangle {
                            border-radius: 18px;
                            border-width: 1px;
                            border-color: root.border;
                            background: root.panel-soft;
                            min-height: 164px;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "Import / Export";
                                    color: root.text-main;
                                    font-size: root.font-section;
                                    font-weight: 700;
                                }

                                Text {
                                    text: root.transfer-path != "" ? root.transfer-path : "Choose a file for import or export";
                                    color: root.text-muted;
                                    wrap: word-wrap;
                                    font-size: root.font-body;
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    AppButton {
                                        text: "Import file";
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.import-data(); }
                                    }

                                    AppButton {
                                        text: "Export file";
                                        primary: true;
                                        panel: root.panel;
                                        panel-alt: root.panel-alt;
                                        accent: root.accent-warm;
                                        border: root.border;
                                        text-main: root.text-main;
                                        text-muted: root.text-muted;
                                        font-scale: root.font-scale;
                                        accessibility-mode: root.accessibility-mode;
                                        clicked => { root.export-data(); }
                                    }
                                }

                                if (root.tools-message != "") : Text {
                                    text: root.tools-message;
                                    color: root.text-muted;
                                    wrap: word-wrap;
                                    font-size: root.font-body;
                                }
                            }
                        }

                        for tab[index] in root.managed-tabs : TabManagerCard {
                            tab: tab;
                            font-scale: root.font-scale;
                            accessibility-mode: root.accessibility-mode;
                            panel: Math.mod(index, 2) == 0 ? root.panel-soft : root.panel;
                            border: root.border;
                            accent: root.accent;
                            text-main: root.text-main;
                            text-muted: root.text-muted;
                            move-up(name) => { root.move-tab-up(name); }
                            move-down(name) => { root.move-tab-down(name); }
                            remove(name) => { root.delete-tab(name); }
                        }

                        Rectangle {
                            border-radius: 18px;
                            border-width: 1px;
                            border-color: root.border;
                            background: root.panel-soft;
                            min-height: 184px;

                            VerticalLayout {
                                padding: 14px;
                                padding-bottom: 18px;
                                spacing: 8px;

                                Text {
                                    text: "About";
                                    color: root.text-main;
                                    font-size: root.font-section;
                                    font-weight: 700;
                                }

                                Text {
                                    text: "Minimal desktop checklist";
                                    color: root.text-muted;
                                    wrap: word-wrap;
                                    font-size: root.font-body;
                                }

                                Rectangle {
                                    width: 72px;
                                    height: 72px;
                                    border-radius: 18px;
                                    background: root.panel;
                                    border-width: 1px;
                                    border-color: root.border;

                                    Image {
                                        x: 8px;
                                        y: 8px;
                                        width: 56px;
                                        height: 56px;
                                        source: @image-url("focus-logo.svg");
                                    }
                                }

                                Text {
                                    text: root.about-repo-url;
                                    color: root.accent;
                                    wrap: word-wrap;
                                    font-size: root.font-body;
                                }

                                Text {
                                    text: root.app-title + " " + root.about-version + "  ·  " + root.about-commit;
                                    color: root.text-main;
                                    wrap: word-wrap;
                                    font-size: root.font-body;
                                }

                                AppButton {
                                    text: "Open project";
                                    primary: true;
                                    panel: root.panel;
                                    panel-alt: root.panel-alt;
                                    accent: root.accent;
                                    border: root.border;
                                    text-main: root.text-main;
                                    text-muted: root.text-muted;
                                    font-scale: root.font-scale;
                                    accessibility-mode: root.accessibility-mode;
                                    clicked => { root.open-project-link(); }
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            border-radius: 18px;
            border-width: 1px;
            border-color: root.border;
            background: root.panel;
            height: 50px;

            HorizontalLayout {
                padding: 12px;
                spacing: 8px;

                if (root.can-undo) : AppButton {
                    text: "Undo";
                    panel: root.panel;
                    panel-alt: root.panel-alt;
                    accent: root.accent-warm;
                    border: root.border;
                    text-main: root.text-main;
                    text-muted: root.text-muted;
                    font-scale: root.font-scale;
                    accessibility-mode: root.accessibility-mode;
                    clicked => { root.undo-complete(); }
                }

                Text {
                    text: root.footer-text;
                    color: root.text-muted;
                    font-size: root.font-caption;
                    wrap: word-wrap;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }

                Text {
                    text: "P " + root.pending-count + "  T " + root.done-today-count + "  M " + root.done-month-count + "  Y " + root.done-year-count;
                    color: root.text-main;
                    font-size: root.font-caption;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }
    }
}
