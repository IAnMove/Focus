import { Button, LineEdit, ScrollView } from "std-widgets.slint";

export struct TabView {
    name: string,
    priority: string,
    selected: bool,
}

export struct TaskView {
    id: int,
    title: string,
    meta: string,
    due_label: string,
    extra: string,
    is_current: bool,
    has_due_date: bool,
    has_extra: bool,
    progress: float,
}

export struct HistoryView {
    id: int,
    title: string,
    meta: string,
    extra: string,
    has_extra: bool,
}

export struct TabManagerView {
    name: string,
    priority: string,
    can_delete: bool,
}

component TagChip inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <color> accent;
    in property <color> panel;
    in property <color> text-main;
    in property <color> text-muted;
    callback pressed();

    min-width: 68px;
    height: 34px;
    border-radius: 17px;
    border-width: 1px;
    border-color: selected ? accent : #25324e;
    background: selected ? accent : panel;

    Text {
        x: 14px;
        y: (parent.height - self.height) / 2;
        text: label;
        color: selected ? #08111f : text-muted;
        font-size: 12px;
        font-weight: selected ? 700 : 500;
    }

    TouchArea {
        clicked => { root.pressed(); }
    }
}

component MetricPill inherits Rectangle {
    in property <string> label;
    in property <int> value;
    in property <color> panel;
    in property <color> border;
    in property <color> text-main;
    in property <color> text-muted;

    min-width: 84px;
    height: 52px;
    border-radius: 16px;
    border-width: 1px;
    border-color: border;
    background: panel;

    VerticalLayout {
        padding: 10px;
        spacing: 2px;

        Text {
            text: label;
            color: text-muted;
            font-size: 11px;
        }

        Text {
            text: value + "";
            color: text-main;
            font-size: 18px;
            font-weight: 700;
        }
    }
}

component TaskActionButton inherits Button {
    in property <string> caption;
    text: caption;
}

component TaskCard inherits Rectangle {
    in property <TaskView> task;
    in property <color> panel;
    in property <color> panel-alt;
    in property <color> accent;
    in property <color> border;
    in property <color> text-main;
    in property <color> text-muted;
    callback complete(task-id: int);
    callback edit(task-id: int);
    callback remove(task-id: int);
    callback toggle-current(task-id: int);
    callback move-up(task-id: int);
    callback move-down(task-id: int);
    callback cycle-tab(task-id: int);

    border-radius: 18px;
    border-width: 1px;
    border-color: task.is_current ? accent : border;
    background: task.is_current ? panel-alt : panel;
    min-height: task.has_extra ? 156px : 132px;

    VerticalLayout {
        padding: 14px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 10px;

            Rectangle {
                width: 18px;
                height: 18px;
                border-radius: 9px;
                border-width: 2px;
                border-color: task.is_current ? accent : text-muted;
                background: transparent;
            }

            VerticalLayout {
                spacing: 4px;
                horizontal-stretch: 1;

                Text {
                    text: task.title;
                    color: text-main;
                    wrap: word-wrap;
                    font-size: 15px;
                    font-weight: task.is_current ? 700 : 600;
                }

                Text {
                    text: task.meta;
                    color: text-muted;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }

            if (task.is_current) : Rectangle {
                border-radius: 12px;
                background: accent;
                min-width: 66px;
                height: 26px;

                Text {
                    x: 12px;
                    y: (parent.height - self.height) / 2;
                    text: "Current";
                    color: #08111f;
                    font-size: 11px;
                    font-weight: 800;
                }
            }
        }

        if (task.has_due_date) : Rectangle {
            border-radius: 10px;
            border-width: 1px;
            border-color: border;
            background: #111827;
            height: 30px;

            Text {
                x: 10px;
                y: (parent.height - self.height) / 2;
                text: task.due_label;
                color: text-muted;
                font-size: 11px;
            }
        }

        if (task.has_due_date) : Rectangle {
            border-radius: 4px;
            background: #0f1728;
            height: 8px;

            Rectangle {
                x: 0;
                y: 0;
                height: parent.height;
                width: parent.width * task.progress;
                border-radius: 4px;
                background: accent;
            }
        }

        if (task.has_extra) : Text {
            text: task.extra;
            color: text-muted;
            wrap: word-wrap;
            font-size: 12px;
        }

        HorizontalLayout {
            spacing: 6px;

            TaskActionButton {
                caption: "Done";
                clicked => { root.complete(task.id); }
            }

            TaskActionButton {
                caption: task.is_current ? "Unpin" : "Current";
                clicked => { root.toggle-current(task.id); }
            }

            TaskActionButton {
                caption: "Edit";
                clicked => { root.edit(task.id); }
            }

            TaskActionButton {
                caption: "Delete";
                clicked => { root.remove(task.id); }
            }

            TaskActionButton {
                caption: "Up";
                clicked => { root.move-up(task.id); }
            }

            TaskActionButton {
                caption: "Down";
                clicked => { root.move-down(task.id); }
            }

            TaskActionButton {
                caption: "Next tab";
                clicked => { root.cycle-tab(task.id); }
            }
        }
    }
}

component HistoryCard inherits Rectangle {
    in property <HistoryView> entry;
    in property <color> panel;
    in property <color> border;
    in property <color> accent;
    in property <color> text-main;
    in property <color> text-muted;
    callback restore(task-id: int);

    border-radius: 18px;
    border-width: 1px;
    border-color: border;
    background: panel;
    min-height: entry.has_extra ? 128px : 104px;

    VerticalLayout {
        padding: 14px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 10px;

            Rectangle {
                width: 18px;
                height: 18px;
                border-radius: 9px;
                background: accent;
            }

            VerticalLayout {
                spacing: 4px;
                horizontal-stretch: 1;

                Text {
                    text: entry.title;
                    color: text-main;
                    wrap: word-wrap;
                    font-size: 15px;
                    font-weight: 600;
                }

                Text {
                    text: entry.meta;
                    color: text-muted;
                    wrap: word-wrap;
                    font-size: 11px;
                }
            }

            Button {
                text: "Restore";
                clicked => { root.restore(entry.id); }
            }
        }

        if (entry.has_extra) : Text {
            text: entry.extra;
            color: text-muted;
            wrap: word-wrap;
            font-size: 12px;
        }
    }
}

component TabManagerCard inherits Rectangle {
    in property <TabManagerView> tab;
    in property <color> panel;
    in property <color> border;
    in property <color> text-main;
    in property <color> text-muted;
    callback move-up(name: string);
    callback move-down(name: string);
    callback remove(name: string);

    border-radius: 16px;
    border-width: 1px;
    border-color: border;
    background: panel;
    min-height: 82px;

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;

            VerticalLayout {
                spacing: 2px;
                horizontal-stretch: 1;

                Text {
                    text: tab.name;
                    color: text-main;
                    font-size: 14px;
                    font-weight: 700;
                }

                Text {
                    text: "Priority: " + tab.priority;
                    color: text-muted;
                    font-size: 11px;
                }
            }

            Button {
                text: "Up";
                clicked => { root.move-up(tab.name); }
            }

            Button {
                text: "Down";
                clicked => { root.move-down(tab.name); }
            }

            if (tab.can_delete) : Button {
                text: "Delete";
                clicked => { root.remove(tab.name); }
            }
        }
    }
}

export component AppWindow inherits Window {
    in-out property <string> app-title: "focus";
    in-out property <string> status-text: "Loading";
    in-out property <string> footer-text: "";
    in-out property <bool> on-top-enabled: true;
    in-out property <string> current-title: "";
    in-out property <string> current-meta: "";
    in-out property <string> active-tab-name: "All";
    in-out property <[TabView]> tabs: [];
    in-out property <[TaskView]> tasks: [];
    in-out property <[HistoryView]> history-items: [];
    in-out property <[TabManagerView]> managed-tabs: [];
    in-out property <int> pending-count: 0;
    in-out property <int> done-today-count: 0;
    in-out property <int> done-month-count: 0;
    in-out property <int> done-year-count: 0;
    in-out property <string> draft-title: "";
    in-out property <string> draft-extra: "";
    in-out property <string> draft-tab-name: "";
    in-out property <bool> editing-mode: false;
    in-out property <bool> can-undo: false;
    in-out property <bool> history-visible: false;
    in-out property <bool> tools-visible: false;

    callback add-task();
    callback show-history();
    callback show-tools();
    callback toggle-on-top();
    callback select-tab(name: string);
    callback submit-draft();
    callback cancel-draft();
    callback complete-task(task-id: int);
    callback edit-task(task-id: int);
    callback delete-task(task-id: int);
    callback toggle-current(task-id: int);
    callback undo-complete();
    callback restore-history(task-id: int);
    callback move-task-up(task-id: int);
    callback move-task-down(task-id: int);
    callback cycle-task-tab(task-id: int);
    callback submit-tab();
    callback move-tab-up(name: string);
    callback move-tab-down(name: string);
    callback delete-tab(name: string);

    title: app-title;
    width: 460px;
    height: 740px;
    background: #0b1120;

    property <color> panel: #121a2b;
    property <color> panel-alt: #17233a;
    property <color> panel-soft: #0f1728;
    property <color> accent: #75e6da;
    property <color> accent-warm: #f7c873;
    property <color> text-main: #f7f8fc;
    property <color> text-muted: #94a3b8;
    property <color> border: #24314d;
    property <bool> has-current-task: current-title != "";

    VerticalLayout {
        padding: 14px;
        spacing: 12px;

        Rectangle {
            border-radius: 24px;
            border-width: 1px;
            border-color: root.border;
            background: root.panel;
            height: 94px;

            HorizontalLayout {
                padding: 14px;
                spacing: 10px;

                VerticalLayout {
                    spacing: 4px;
                    horizontal-stretch: 1;

                    Text {
                        text: root.app-title;
                        color: root.text-main;
                        font-size: 24px;
                        font-weight: 800;
                    }

                    Text {
                        text: root.status-text;
                        color: root.text-muted;
                        font-size: 12px;
                    }
                }

                VerticalLayout {
                    spacing: 6px;

                    Button {
                        text: root.editing-mode ? "Editing" : "Add task";
                        clicked => { root.add-task(); }
                    }

                    HorizontalLayout {
                        spacing: 6px;

                        Button {
                            text: root.history-visible ? "Back" : "History";
                            clicked => { root.show-history(); }
                        }

                        Button {
                            text: root.tools-visible ? "Close tools" : "Tools";
                            clicked => { root.show-tools(); }
                        }

                        Button {
                            text: root.on-top-enabled ? "Pinned" : "Pin";
                            clicked => { root.toggle-on-top(); }
                        }
                    }
                }
            }
        }

        Rectangle {
            border-radius: 22px;
            border-width: 1px;
            border-color: root.border;
            background: root.panel;
            min-height: 126px;
            visible: !root.history-visible && !root.tools-visible;

            VerticalLayout {
                padding: 14px;
                spacing: 8px;

                Text {
                    text: root.editing-mode ? "Edit task" : "Quick add";
                    color: root.text-main;
                    font-size: 15px;
                    font-weight: 700;
                }

                LineEdit {
                    text <=> root.draft-title;
                    placeholder-text: "Task title";
                }

                LineEdit {
                    text <=> root.draft-extra;
                    placeholder-text: "Extra info (optional)";
                }

                HorizontalLayout {
                    spacing: 8px;

                    Button {
                        text: root.editing-mode ? "Save" : "Create";
                        clicked => { root.submit-draft(); }
                    }

                    Button {
                        text: "Cancel";
                        enabled: root.editing-mode || root.draft-title != "" || root.draft-extra != "";
                        clicked => { root.cancel-draft(); }
                    }

                    if (root.can-undo) : Button {
                        text: "Undo";
                        clicked => { root.undo-complete(); }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;

            MetricPill {
                label: "Pending";
                value: root.pending-count;
                panel: root.panel;
                border: root.border;
                text-main: root.text-main;
                text-muted: root.text-muted;
            }

            MetricPill {
                label: "Today";
                value: root.done-today-count;
                panel: root.panel;
                border: root.border;
                text-main: root.text-main;
                text-muted: root.text-muted;
            }

            MetricPill {
                label: "Month";
                value: root.done-month-count;
                panel: root.panel;
                border: root.border;
                text-main: root.text-main;
                text-muted: root.text-muted;
            }

            MetricPill {
                label: "Year";
                value: root.done-year-count;
                panel: root.panel;
                border: root.border;
                text-main: root.text-main;
                text-muted: root.text-muted;
            }
        }

        Rectangle {
            border-radius: 20px;
            border-width: 1px;
            border-color: root.border;
            background: root.panel;
            height: 54px;
            visible: !root.history-visible && !root.tools-visible;

            HorizontalLayout {
                padding: 9px;
                spacing: 8px;

                TagChip {
                    label: "Tools";
                    selected: false;
                    accent: root.accent-warm;
                    panel: root.panel-soft;
                    text-main: root.text-main;
                    text-muted: root.text-muted;
                    pressed => { root.show-tools(); }
                }

                for tab in root.tabs : TagChip {
                    label: tab.name;
                    selected: tab.selected;
                    accent: root.accent;
                    panel: root.panel-soft;
                    text-main: root.text-main;
                    text-muted: root.text-muted;
                    pressed => { root.select-tab(tab.name); }
                }
            }
        }

        if (root.has-current-task) : Rectangle {
            border-radius: 24px;
            border-width: 1px;
            border-color: root.accent;
            background: root.panel-alt;
            min-height: 108px;
            visible: !root.history-visible && !root.tools-visible;

            VerticalLayout {
                padding: 16px;
                spacing: 6px;

                Text {
                    text: "Current task";
                    color: root.accent;
                    font-size: 12px;
                    font-weight: 800;
                }

                Text {
                    text: root.current-title;
                    color: root.text-main;
                    wrap: word-wrap;
                    font-size: 20px;
                    font-weight: 700;
                }

                Text {
                    text: root.current-meta;
                    color: root.text-muted;
                    wrap: word-wrap;
                    font-size: 12px;
                }
            }
        }

        Rectangle {
            border-radius: 24px;
            border-width: 1px;
            border-color: root.border;
            background: root.panel;
            vertical-stretch: 1;

            VerticalLayout {
                padding: 14px;
                spacing: 10px;

                HorizontalLayout {
                    spacing: 8px;

                    VerticalLayout {
                        spacing: 2px;
                        horizontal-stretch: 1;

                        Text {
                            text: root.tools-visible ? "Tools" : (root.history-visible ? "History" : (root.active-tab-name == "All" ? "All tasks" : root.active-tab-name));
                            color: root.text-main;
                            font-size: 18px;
                            font-weight: 700;
                        }

                        Text {
                            text: root.footer-text;
                            color: root.text-muted;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }

                    Rectangle {
                        width: 40px;
                        height: 40px;
                        border-radius: 20px;
                        background: root.accent-warm;

                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: root.pending-count + "";
                            color: #111827;
                            font-size: 16px;
                            font-weight: 800;
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    background: root.border;
                }

                if (!root.history-visible && !root.tools-visible && root.tasks.length == 0) : Rectangle {
                    border-radius: 18px;
                    border-width: 1px;
                    border-color: root.border;
                    background: root.panel-soft;
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 20px;
                        spacing: 8px;

                        Text {
                            text: "No tasks in this view";
                            color: root.text-main;
                            font-size: 18px;
                            font-weight: 700;
                        }

                        Text {
                            text: "Use the quick add panel to create the next task.";
                            color: root.text-muted;
                            wrap: word-wrap;
                            font-size: 13px;
                        }
                    }
                }

                if (!root.history-visible && !root.tools-visible && root.tasks.length > 0) : ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 10px;
                        padding-right: 2px;

                        for task[index] in root.tasks : TaskCard {
                            task: task;
                            panel: Math.mod(index, 2) == 0 ? root.panel-soft : root.panel;
                            panel-alt: root.panel-alt;
                            accent: root.accent;
                            border: root.border;
                            text-main: root.text-main;
                            text-muted: root.text-muted;
                            complete(task-id) => { root.complete-task(task-id); }
                            edit(task-id) => { root.edit-task(task-id); }
                            remove(task-id) => { root.delete-task(task-id); }
                            toggle-current(task-id) => { root.toggle-current(task-id); }
                            move-up(task-id) => { root.move-task-up(task-id); }
                            move-down(task-id) => { root.move-task-down(task-id); }
                            cycle-tab(task-id) => { root.cycle-task-tab(task-id); }
                        }
                    }
                }

                if (root.history-visible && root.history-items.length == 0) : Rectangle {
                    border-radius: 18px;
                    border-width: 1px;
                    border-color: root.border;
                    background: root.panel-soft;
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 20px;
                        spacing: 8px;

                        Text {
                            text: "No completed tasks yet";
                            color: root.text-main;
                            font-size: 18px;
                            font-weight: 700;
                        }

                        Text {
                            text: "Completed tasks will appear here and can be restored.";
                            color: root.text-muted;
                            wrap: word-wrap;
                            font-size: 13px;
                        }
                    }
                }

                if (root.history-visible && root.history-items.length > 0) : ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 10px;
                        padding-right: 2px;

                        for entry[index] in root.history-items : HistoryCard {
                            entry: entry;
                            panel: Math.mod(index, 2) == 0 ? root.panel-soft : root.panel;
                            border: root.border;
                            accent: root.accent-warm;
                            text-main: root.text-main;
                            text-muted: root.text-muted;
                            restore(task-id) => { root.restore-history(task-id); }
                        }
                    }
                }

                if (root.tools-visible) : ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 12px;
                        padding-right: 2px;

                        Rectangle {
                            border-radius: 18px;
                            border-width: 1px;
                            border-color: root.border;
                            background: root.panel-soft;
                            min-height: 118px;

                            VerticalLayout {
                                padding: 14px;
                                spacing: 8px;

                                Text {
                                    text: "Add tab";
                                    color: root.text-main;
                                    font-size: 15px;
                                    font-weight: 700;
                                }

                                LineEdit {
                                    text <=> root.draft-tab-name;
                                    placeholder-text: "New tab name";
                                }

                                Button {
                                    text: "Create tab";
                                    clicked => { root.submit-tab(); }
                                }
                            }
                        }

                        for tab[index] in root.managed-tabs : TabManagerCard {
                            tab: tab;
                            panel: Math.mod(index, 2) == 0 ? root.panel-soft : root.panel;
                            border: root.border;
                            text-main: root.text-main;
                            text-muted: root.text-muted;
                            move-up(name) => { root.move-tab-up(name); }
                            move-down(name) => { root.move-tab-down(name); }
                            remove(name) => { root.delete-tab(name); }
                        }
                    }
                }
            }
        }
    }
}
